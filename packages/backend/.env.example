PORT=8080
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres

# If Postgres returns SELF_SIGNED_CERT_IN_CHAIN (common with some pools / proxies), allow local dev only:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# --- Existing web-app menu (/api/mobile/menu, /api/mobile/set-menus) ---
# If you omit WEB_MENU_SQL / WEB_MENU_TABLE (and WEB_SET_*), defaults query
# public.menu_dishes + public.set_menus (Curatering web schema).
# Set DISABLE_DEFAULT_PUBLIC_MENU=true to require explicit SQL instead.
#
# DISABLE_DEFAULT_PUBLIC_MENU=true

# Option A — full SQL (recommended). Must return columns: id, name, description, price, dips
# dips should be JSON text array, e.g. '["Garlic Mayo"]' or a json/jsonb column cast to text.
#
# WEB_MENU_SQL=SELECT id, name, description, price::numeric,
#   COALESCE(dips::text, '[]') AS dips FROM YOUR_DISH_TABLE WHERE deleted_at IS NULL ORDER BY id

# Option B — table + columns (alternative to WEB_MENU_SQL):
# WEB_MENU_SCHEMA=public
# WEB_MENU_TABLE=your_dishes_table
# WEB_MENU_ID_COL=id
# WEB_MENU_NAME_COL=name
# WEB_MENU_DESC_COL=description
# WEB_MENU_PRICE_COL=price
# WEB_MENU_DIPS_COL=dips
# WEB_MENU_WHERE=is_available = true

# --- Optional: set menus from existing web table ---
# WEB_SET_MENUS_SQL=SELECT name, description, dishes::text AS dishes FROM your_set_menu_table
# Or:
# WEB_SET_MENU_TABLE=your_set_menu_table
# WEB_SET_MENU_NAME_COL=name
# WEB_SET_MENU_DESC_COL=description
# WEB_SET_MENU_DISHES_COL=dishes

# --- Email (OTP + notifications + PDFs) ---
#
# Railway Free/Hobby often blocks outbound SMTP (ports 465/587) — connection hangs then ETIMEDOUT.
# Recommended: Resend over HTTPS (no SMTP). Create a key at https://resend.com and verify your sending domain.
#
RESEND_API_KEY=
# Must be a sender Resend allows for your account (verified domain, or onboarding@resend.dev for limited testing).
# Use EXACTLY one of these shapes (no JSON escaping). In Railway, do not wrap the whole value in extra quotes.
#   RESEND_FROM=noreply@curatering.com
#   RESEND_FROM=Curatering <noreply@curatering.com>
# Wrong:  ""noreply@...""  or  Curatering noreply@...  (missing angle brackets) → Resend HTTP 422.
#
# RESEND_FROM=noreply@curatering.com
#
# --- SMTP (optional; used only when RESEND_API_KEY is unset) ---
# Gmail: full address + App Password, not your normal password
TRANSPORTER_EMAIL=
TRANSPORTER_PASSWORD=
# Same server picks up optional host/port (defaults: smtp.gmail.com, 465)
# TRANSPORTER_SMTP_HOST=smtp.gmail.com
# TRANSPORTER_SMTP_PORT=465
#
# Alternatives (first non-empty user+password pair wins in code):
# GMAIL_USER= / GMAIL_APP_PASSWORD=
# Optional "From" when it differs from the login user:
# TRANSPORTER_FROM=
# SMTP_FROM=

# --- AI event theme design (RunPod img2img; keys stay on server only) ---
# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=

# OTP expiry (minutes)
MOBILE_OTP_EXPIRY_MINUTES=15

# Local dev only: if SMTP is not set, log signup/password-reset OTPs to the server console instead of emailing.
# Do not enable in production.
# MOBILE_DEV_OTP_LOGGING=true

# Optional: emailed when a customer uploads balance payment proof after insufficient payment
# CASHIER_BALANCE_NOTIFY_EMAIL=
